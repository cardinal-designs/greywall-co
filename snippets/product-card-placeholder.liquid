{% comment %}
    Renders a product card placeholder

    Usage:
    {% render 'product-card-placeholder' %}
{% endcomment %}

<div>
  <div class="aspect-product relative">
    {% render 'image'
      classes: 'size-full inset object-cover',
      sizes: '700x',
      include_placeholder: true,
      placeholder_name: 'product-1',
      src_set_type: 'grid'
    %}
  </div>
  <div class="mt-20 text-center">
    <p class="text-m-h4 font-serif uppercase md:text-h5">Product title</p>
  </div>
</div>